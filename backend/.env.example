# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Image expiry (seconds) ────────────────────────────────────────────────────
# How long a labeler can hold an image before it is reassigned.
IMAGE_ASSIGNMENT_TIMEOUT_SECONDS=1800

# How often the expiry sweeper runs.
IMAGE_EXPIRY_INTERVAL_SECONDS=300

# ── Database  ────────────────────────
DATABASE_URL=postgresql+asyncpg://ulabel:secret@localhost:5432/ulabel
TEST_DATABASE_URL=postgresql+asyncpg://ulabel:secret@localhost:5432/ulabel

# ── Object storage ─────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ulabel

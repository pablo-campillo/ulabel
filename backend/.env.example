# Secrets and environment-specific overrides.
# Non-secret config lives in config.yml.
# Copy this file to .env and fill in the values — .env is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ulabel:secret@localhost:5432/ulabel
TEST_DATABASE_URL=postgresql+asyncpg://ulabel:secret@localhost:5432/ulabel

# ── Object storage credentials ───────────────────────────────────────────────
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# ── Optional overrides (uncomment to override config.yml defaults) ───────────
# STORAGE_ENDPOINT=localhost:9000
# STORAGE_PUBLIC_ENDPOINT=

{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "dashboard",
      "tags": [],
      "title": "Overview",
      "type": "link",
      "url": "/d/ulabel-overview"
    },
    {
      "asDropdown": false,
      "icon": "dashboard",
      "tags": [],
      "title": "Labeling Activity",
      "type": "link",
      "url": "/d/ulabel-labeling-activity"
    }
  ],
  "panels": [
    {
      "title": "Errors / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"ulabel-backend\"} | json | level = \"ERROR\" [5m])) / 5"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Warnings / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"ulabel-backend\"} | json | level = \"WARNING\" [5m])) / 5"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Domain Errors / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"ulabel-backend\"} |= \"Domain error\" [5m])) / 5"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Expired Assignments / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"ulabel-backend\"} |= \"Expired\" |= \"stale assignments\" [5m])) / 5"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Trace Search",
      "description": "Search traces by endpoint and minimum duration. Click a trace to view its full span waterfall in Tempo.",
      "type": "traces",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "resource.service.name",
              "operator": "=",
              "value": ["ulabel-backend"],
              "scope": "resource"
            },
            {
              "id": "min-duration",
              "tag": "duration",
              "operator": ">",
              "value": ["$min_duration"]
            }
          ],
          "limit": 50
        }
      ],
      "options": {}
    },
    {
      "title": "Trace Duration by Endpoint",
      "description": "P95 and P50 latency per endpoint, filtered by the selected endpoints.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{path=~\"$endpoint\"}[1m])) by (le, path))",
          "legendFormat": "P95 {{ path }}",
          "exemplar": true,
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{path=~\"$endpoint\"}[1m])) by (le, path))",
          "legendFormat": "P50 {{ path }}",
          "exemplar": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Recent Traces",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"ulabel-backend\"} | json | level = \"INFO\" | trace_id != \"\" | trace_id != \"0\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "showLabels": false
      }
    },
    {
      "title": "Error & Warning Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"ulabel-backend\"} | json | level = \"ERROR\" [1m]))",
          "legendFormat": "ERROR"
        },
        {
          "expr": "sum(count_over_time({service=\"ulabel-backend\"} | json | level = \"WARNING\" [1m]))",
          "legendFormat": "WARNING"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "fillOpacity": 20, "drawStyle": "bars", "stacking": { "mode": "normal" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARNING" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Log Volume by Logger",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (logger) (count_over_time({service=\"ulabel-backend\"} | json [1m]))",
          "legendFormat": "{{ logger }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "fillOpacity": 20, "drawStyle": "bars", "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{service=\"ulabel-backend\"} | json | level =~ \"ERROR|WARNING\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "showLabels": true
      }
    },
    {
      "title": "Full Log Stream",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 54 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{service=\"ulabel-backend\"} | json | level =~ \"$level\" | logger =~ \"$logger\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "showLabels": true
      }
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" }
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(http_requests_total, path)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "refresh": 2
      },
      {
        "name": "min_duration",
        "label": "Min Duration",
        "type": "custom",
        "query": "0s,100ms,250ms,500ms,1s,2s,5s",
        "current": { "text": "0s", "value": "0s" }
      },
      {
        "name": "level",
        "type": "custom",
        "query": "DEBUG,INFO,WARNING,ERROR",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true
      },
      {
        "name": "logger",
        "type": "custom",
        "query": "ulabel.api.routers.tokens,ulabel.api.routers.projects,ulabel.api.routers.images,ulabel.api.routers.assignments,ulabel.api.routers.exports,ulabel.api.error_handlers",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "uLabel Traces & Logs",
  "uid": "ulabel-traces-logs",
  "version": 3
}
